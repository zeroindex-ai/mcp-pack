{
  "name": "@zeroindex-ai/mcp-turso",
  "version": "0.1.1",
  "description": "MCP server exposing read-only Turso Platform API (databases, groups, usage) to Claude and other MCP clients",
  "type": "module",
  "bin": {
    "mcp-turso": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@zeroindex-ai/_http": "workspace:*",
    "zod": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeroindex-ai/mcp-pack.git",
    "directory": "packages/turso"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "turso",
    "libsql",
    "sqlite",
    "database"
  ]
}
