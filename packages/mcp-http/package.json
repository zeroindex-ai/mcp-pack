{
  "name": "@zeroindex-ai/mcp-http",
  "version": "0.2.2",
  "description": "Small HTTP client shared by @zeroindex-ai/mcp-* servers — auth (bearer/body/none), 30s timeout, 429 + x-ratelimit-remaining retry, structured HttpError.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeroindex-ai/mcp-pack.git",
    "directory": "packages/mcp-http"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "http",
    "http-client",
    "rate-limit",
    "retry"
  ]
}
